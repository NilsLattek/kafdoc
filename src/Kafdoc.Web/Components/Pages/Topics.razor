@page "/"
@rendermode InteractiveServer
@using Kafdoc.Application.Services
@inject ITopicQueryService TopicQuery
@inject ISnapshotStatusService Status

<PageTitle>Topics</PageTitle>

<div class="kd-page">
    <header class="kd-head">
        <p class="kd-eyebrow">Kafka cluster</p>
        <h1 class="kd-title">Topics</h1>
        <p class="kd-sub">Producers, consumer groups, and docs for every topic in the snapshot.</p>
    </header>

    <RefreshStatus />

    @if (!Status.GetStatus().IsReady)
    {
        <div class="kd-empty--block">Loading cluster data…</div>
    }
    else
    {
        var topics = Filtered().ToList();

        <div class="kd-toolbar">
            <input class="kd-search" placeholder="Filter topics…" @bind="_filter" @bind:event="oninput" />
            <span class="kd-count">@topics.Count of @TopicQuery.GetTopics().Count</span>
        </div>

        <div class="kd-table-wrap">
            <table class="kd-table">
                <thead>
                    <tr>
                        <th>Topic</th>
                        <th class="kd-num">Partitions</th>
                        <th class="kd-num">Producers</th>
                        <th class="kd-num">Groups</th>
                        <th class="kd-col-status">Docs</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var topic in topics)
                    {
                        <tr>
                            <td><a class="kd-id" href="@($"/topics/{Uri.EscapeDataString(topic.Name)}")">@topic.Name</a></td>
                            <td class="kd-num">@topic.PartitionCount</td>
                            <td class="kd-num @(topic.ProducerCount == 0 ? "kd-num--zero" : null)">@topic.ProducerCount</td>
                            <td class="kd-num @(topic.ConsumerGroupCount == 0 ? "kd-num--zero" : null)">@topic.ConsumerGroupCount</td>
                            <td class="kd-col-status">
                                @if (topic.HasDocumentation)
                                {
                                    <span class="kd-pill kd-pill--doc">Documented</span>
                                }
                                else
                                {
                                    <span class="kd-muted">—</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (topics.Count == 0)
                    {
                        <tr>
                            <td colspan="5" class="kd-empty">No topics match “@_filter”.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private string _filter = string.Empty;

    private IEnumerable<Kafdoc.Application.Dtos.TopicSummaryDto> Filtered() =>
        TopicQuery.GetTopics()
            .Where(t => string.IsNullOrWhiteSpace(_filter)
                || t.Name.Contains(_filter, StringComparison.OrdinalIgnoreCase));
}
