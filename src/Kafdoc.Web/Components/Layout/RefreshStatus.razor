@rendermode InteractiveServer
@using Kafdoc.Application.Services
@using Kafdoc.Application.Snapshot
@inject ISnapshotStatusService Status
@inject IServiceScopeFactory ScopeFactory

@{
    var status = Status.GetStatus();
}
<div class="kd-status" role="status">
    <span>
        <span class="kd-status__dot @(status.LastError is null ? null : "kd-status__dot--err")" aria-hidden="true"></span>
        @if (status.LastRefresh is { } when)
        {
            <span>Last refreshed <time>@when.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss")</time></span>
        }
        else
        {
            <span>Never refreshed</span>
        }
        @if (status.LastError is { } error)
        {
            <span class="kd-status__err">⚠ Last refresh failed: @error</span>
        }
    </span>
    <button class="kd-btn" @onclick="RefreshNow" disabled="@_refreshing">
        @(_refreshing ? "Refreshing…" : "Refresh now")
    </button>
</div>

@code {
    private bool _refreshing;

    private async Task RefreshNow()
    {
        _refreshing = true;
        try
        {
            await using var scope = ScopeFactory.CreateAsyncScope();
            var refresh = scope.ServiceProvider.GetRequiredService<IClusterRefreshService>();
            await refresh.RefreshAsync(CancellationToken.None);
        }
        finally
        {
            _refreshing = false;
        }
    }
}
